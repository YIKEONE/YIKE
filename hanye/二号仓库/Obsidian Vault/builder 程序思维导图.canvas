		{"id":"816b3a981457d432","type":"text","text":"class ProgressValueModifier","x":381,"y":240,"width":182,"height":57},
		{"id":"e6d768aeab58e497","type":"text","text":"makeContentModifierNode","x":395,"y":100,"width":161,"height":77},
		{"id":"e3edd2342c6c0dfc","type":"text","text":"enable","x":551,"y":-60,"width":146,"height":50,"color":"1"},
		{"id":"61e2847970ba669d","type":"text","text":"progress_pattern,cpp","x":140,"y":582,"width":201,"height":70},
		{"id":"6de292a15c16e0e0","type":"text","text":"OnModifyDone","x":413,"y":592,"width":141,"height":50},
